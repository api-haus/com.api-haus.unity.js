<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <IsRoslynComponent>true</IsRoslynComponent>
    <ManageWorkloadToolsets>false</ManageWorkloadToolsets>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.1.0" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Tests/**" />
  </ItemGroup>

  <Target Name="CopyToPlugins" AfterTargets="Build" Condition="'$(Configuration)' == 'Release'">
    <Copy SourceFiles="$(OutputPath)LuaGameCodegen.dll"
          DestinationFolder="../Runtime/Plugins/" />
  </Target>
</Project>
